{
    "compilerOptions": {
      "allowJs": true,
      "checkJs": false,
      "skipLibCheck": true,
      "noImplicitAny": false,
      "noEmit": true,
      "jsx": "react",
      "module": "ESNext",
      "target": "ES2022",
      "removeComments": true,
      "preserveConstEnums": true,
      "sourceMap": true,
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "moduleResolution": "node",
      "importHelpers": true,
      "types": ["node", "jest"],
      "baseUrl": "./src",
      "paths": {
        "@Entity/*": ["Entity/*"],
        "@DataGateway/*": ["Gateway/Data/*"],
        "@Interactor/*": ["Interactor/*"],
        "@View/*": ["View/*"]
      }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules"]
}